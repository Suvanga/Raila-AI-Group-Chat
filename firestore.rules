rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users ---
    // Anyone authenticated can read user profiles (for search).
    // Users can only write their own profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // lastRead sub-collection — only the owning user
      match /lastRead/{chatId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- Public messages ---
    // Any authenticated user can read/write the public chat.
    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // --- Chats (groups + DMs) ---
    match /chats/{chatId} {
      // Anyone authenticated can read chat metadata to check membership.
      // Only members can read.
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.members);

      // Authenticated users can create chats (groups or DMs).
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;

      // Only members can update chat metadata.
      allow update: if request.auth != null
        && request.auth.uid in resource.data.members;

      // Messages sub-collection — only members of the parent chat can read/write.
      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
      }

      // Typing sub-collection — only members can read/write.
      match /typing/{userId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow write: if request.auth != null
          && request.auth.uid == userId;
      }
    }

    // --- Public chat typing indicators ---
    match /typing/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Presence ---
    match /presence/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Invite Codes ---
    // Managed via Cloud Functions; direct client access is read-only for admins
    match /invites/{codeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
