rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function safeUserProfileFields() {
      return ['displayName', 'email', 'photoURL', 'lastSeen'];
    }

    function allowedMessageFields() {
      return [
        'text',
        'createdAt',
        'uid',
        'email',
        'photoURL',
        'reactions',
        'replyTo',
        'fileURL',
        'fileName',
        'fileType',
        'isImage',
        'pinned',
      ];
    }

    function onlyMutableMessageFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'pinned']);
    }

    function isChatMember(chatId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
    }

    function isAuthorCreate() {
      return request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(allowedMessageFields());
    }

    function isAuthorDelete() {
      return resource.data.uid == request.auth.uid;
    }

    function isMessageInteractionUpdate() {
      return request.resource.data.keys().hasOnly(allowedMessageFields())
        && onlyMutableMessageFieldsChanged();
    }

    function isSelfLeaveUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'membersInfo'])
        && request.auth.uid in resource.data.members
        && resource.data.members.hasAll(request.resource.data.members)
        && request.resource.data.members.size() == resource.data.members.size() - 1
        && !(request.auth.uid in request.resource.data.members)
        && resource.data.membersInfo is list
        && request.resource.data.membersInfo is list
        && resource.data.membersInfo.hasAll(request.resource.data.membersInfo)
        && request.resource.data.membersInfo.size() == resource.data.membersInfo.size() - 1
        && request.resource.data.members.size() == request.resource.data.membersInfo.size();
    }

    // --- Users ---
    // Anyone authenticated can read user profiles (for search).
    // Users can only write safe fields on their own profile.
    // Approval, invite, and role fields are server-managed and cannot be set by clients.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId)
        && request.resource.data.keys().hasOnly(safeUserProfileFields());
      allow update: if isSelf(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(safeUserProfileFields());

      // lastRead sub-collection — only the owning user
      match /lastRead/{chatId} {
        allow read, write: if isSelf(userId);
      }
    }

    // --- Public messages ---
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isAuthorCreate();
      allow update: if isSignedIn() && isMessageInteractionUpdate();
      allow delete: if isSignedIn() && isAuthorDelete();
    }

    // --- Chats (groups + DMs) ---
    match /chats/{chatId} {
      // Only members can read chat metadata.
      allow read: if isSignedIn()
        && (resource == null || request.auth.uid in resource.data.members);

      // Authenticated users can create chats; caller must be a member.
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.members;

      // Client updates are limited to self-leave only.
      allow update: if isSignedIn() && isSelfLeaveUpdate();

      // Messages sub-collection — members only, with ownership checks.
      match /messages/{messageId} {
        allow read: if isChatMember(chatId);
        allow create: if isChatMember(chatId) && isAuthorCreate();
        allow update: if isChatMember(chatId) && isMessageInteractionUpdate();
        allow delete: if isChatMember(chatId) && isAuthorDelete();
      }

      // Typing sub-collection — members can read, only own uid can write.
      match /typing/{userId} {
        allow read: if isChatMember(chatId);
        allow write: if isSelf(userId);
      }
    }

    // --- Public chat typing indicators ---
    match /typing/{userId} {
      allow read: if isSignedIn();
      allow write: if isSelf(userId);
    }

    // --- Presence ---
    match /presence/{userId} {
      allow read: if isSignedIn();
      allow write: if isSelf(userId);
    }

    // --- Invite Codes ---
    // Managed via Cloud Functions/Admin SDK only.
    match /invites/{codeId} {
      allow read, write: if false;
    }
  }
}
